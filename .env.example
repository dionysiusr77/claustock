# ── Anthropic ─────────────────────────────────
ANTHROPIC_API_KEY=

# ── Telegram ──────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=          # comma-separated, e.g. 123456,789012

# ── Firebase ──────────────────────────────────
FIREBASE_CRED_JSON=         # full JSON string of service account key

# ── Invezgo ───────────────────────────────────
INVEZGO_API_KEY=            # JWT from api.invezgo.com → Settings → API Key

# ── Capital & Risk ────────────────────────────
CAPITAL_IDR=10000000        # total trading capital in IDR
MAX_POSITIONS=5             # max concurrent open positions
DAILY_LOSS_LIMIT_PCT=3.0    # stop trading if daily loss exceeds this %

# ── Scanner ───────────────────────────────────
MIN_SCORE=60                # minimum score to include in briefing
TOP_N_AI=15                 # top N candidates sent to Claude for briefing
UNIVERSE=IDX80              # LQ45 | IDX80 | COMPOSITE